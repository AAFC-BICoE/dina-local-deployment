{
  "settings": {
    "index": {
      "number_of_shards": "1",
      "number_of_replicas": "1"
    }
  },
  "mappings": {
    "_meta": {
      "version": {
        "number": "1.0"
      }
    },
    "date_detection": true,
    "numeric_detection": false,
    "dynamic_templates": [
      {
        "ids_as_keywords": {
          "path_match": "*.id",
          "mapping": {
            "type": "keyword"
          }
        }
      },
      {
        "type_as_keywords": {
          "match_mapping_type": "string",
          "match": "type",
          "mapping": {
            "type": "keyword"
          }
        }
      },
      {
        "included_as_nested": {
          "match_mapping_type": "object",
          "match": "included",
          "mapping": {
            "type": "nested"
          }
        }
      },
      {
        "verbatim_as_text": {
          "match": "*verbatim*",
          "mapping": {
            "type": "text"
          }
        }
      },
      {
        "dwc_verbatim_as_text": {
          "match": "dwcVerbatim*",
          "mapping": {
            "type": "text"
          }
        }
      },
      {
        "extension_values_as_text": {
          "path_match": "*.extensionValues.*.*",
          "mapping": {
            "type": "text",
            "fields": {
              "keyword": {
                "type": "keyword",
                "ignore_above": 256
              }
            }
          }
        }
      },
      {
        "managed_attributes_integer": {
          "path_match": ".*managedAttributes\\..*_integer",
          "match_pattern": "regex",
          "mapping": {
            "type": "integer"
          }
        }
      },
      {
        "managed_attributes_date": {
          "path_match": ".*managedAttributes\\..*_date",
          "match_pattern": "regex",
          "mapping": {
            "type": "date"
          }
        }
      },
      {
        "managed_attributes_bool": {
          "path_match": ".*managedAttributes\\..*_bool",
          "match_pattern": "regex",
          "mapping": {
            "type": "boolean"
          }
        }
      },
      {
        "managed_attributes_decimal": {
          "path_match": ".*managedAttributes\\..*_decimal",
          "match_pattern": "regex",
          "mapping": {
            "type": "float"
          }
        }
      },
      {
        "managed_attributes_default": {
          "path_match": ".*managedAttributes\\..*",
          "match_pattern": "regex",
          "mapping": {
            "type": "text",
            "fields": {
              "keyword": {
                "type": "keyword",
                "ignore_above": 256
              }
            }
          }
        }
      }
    ],
    "properties": {
      "data": {
        "properties": {
          "type": {
            "type": "constant_keyword",
            "value": "collecting-event"
          },

          "id": {
            "type": "keyword"
          },

          "attributes": {
            "properties": {
              "uuid": { "type": "keyword" },

              "createdBy": { "type": "keyword" },

              "createdOn": { "type": "date" },

              "group": { "type": "keyword" },

              "dwcFieldNumber": {
                "type": "text",
                "fields": {
                  "keyword": { "type": "keyword", "ignore_above": 256 }
                }
              },

              "dwcRecordNumber": {
                "type": "text",
                "fields": {
                  "keyword": { "type": "keyword", "ignore_above": 256 }
                }
              },

              "dwcRecordedBy": {
                "type": "text",
                "fields": {
                  "keyword": { "type": "keyword", "ignore_above": 256 }
                }
              },

              "dwcCountry": { "type": "keyword" },

              "dwcCountryCode": { "type": "keyword" },

              "dwcStateProvince": { "type": "keyword" },

              "dwcVerbatimLocality": {
                "type": "text"
              },

              "habitat": { "type": "text" },

              "substrate": { "type": "text" },

              "host": { "type": "text" },

              "remarks": { "type": "text" },

              "publiclyReleasable": { "type": "boolean" },

              "startEventDateTime": { "type": "date" },

              "endEventDateTime": { "type": "date" },

              "dwcMinimumElevationInMeters": { "type": "float" },

              "dwcMaximumElevationInMeters": { "type": "float" },

              "dwcMinimumDepthInMeters": { "type": "float" },

              "dwcMaximumDepthInMeters": { "type": "float" },

              "eventGeom": {
                "type": "geo_point"
              },

              "tags": {
                "type": "keyword"
              },

              "managedAttributes": {
                "type": "object",
                "dynamic": true
              },

              "extensionValues": {
                "type": "object",
                "dynamic": true
              }
            }
          },

          "relationships": {
            "properties": {
              "site": {
                "properties": {
                  "data": {
                    "properties": {
                      "type": {
                        "type": "constant_keyword",
                        "value": "site"
                      },
                      "id": {
                        "type": "keyword"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },

      "included": {
        "type": "nested",
        "properties": {
          "type": { "type": "keyword" },

          "id": { "type": "keyword" },

          "attributes": {
            "properties": {
              "name": {
                "type": "text",
                "fields": {
                  "keyword": {
                    "type": "keyword",
                    "ignore_above": 256
                  }
                }
              },

              "group": { "type": "keyword" },

              "code": { "type": "keyword" },

              "siteGeom": {
                "type": "geo_point"
              }
            }
          }
        }
      }
    }
  }
}
