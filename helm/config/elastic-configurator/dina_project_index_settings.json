{
  "settings": {
    "index": {
      "number_of_shards": "1",
      "number_of_replicas": "1"
    }
  },
  "mappings": {
    "_meta": {
      "version": {
        "number": "1.3"
      }
    },
    "date_detection": true,
    "numeric_detection": true,
    "dynamic_templates": [
      {
        "includes_as_nested": {
          "match_mapping_type": "object",
          "match": "included",
          "mapping": {
            "type": "nested"
          }
        }
      },
      {
        "id_as_keywords": {
          "match_mapping_type": "string",
          "match": "id",
          "mapping": {
            "type": "keyword"
          }
        }
      },
      {
        "type_as_keywords": {
          "match_mapping_type": "string",
          "match": "type",
          "mapping": {
            "type": "keyword"
          }
        }
      }
    ],
    "properties": {
      "data": {
        "properties": {
          "type": {
            "type": "constant_keyword",
            "value": "project"
          },
          "attributes": {
            "properties": {
              "createdBy": {
                "type": "keyword"
              },
              "createdOn": {
                "type": "date"
              },
              "group": {
                "type": "keyword"
              }
            }
          },
          "relationships": {
            "properties": {
              "attachment": {
                "properties": {
                  "data": {
                    "properties": {
                      "type": {
                        "type": "constant_keyword",
                        "value": "metadata"
                      }
                    }
                  }
                }
              },
              "parentProject": {
                "properties": {
                  "data": {
                    "properties": {
                      "type": {
                        "type": "constant_keyword",
                        "value": "project"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "included": {
        "type": "nested",
        "properties": {
          "attributes": {
            "properties": {
              "materialSamples": {
                "type": "keyword"
              }
            }
          }
        }
      },
      "meta": {
        "properties": {
          "moduleVersion": {
            "type": "keyword"
          }
        }
      }
    }
  }
}
